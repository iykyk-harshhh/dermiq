rules_version = '2';

// DermIQ Firestore security rules.
// Every user can only read/write their own document tree under users/{uid}.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      // Per-user subcollections: shelf, routines, analysis, checkIns.
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Global catalog — readable by any signed-in user; writes are admin-only
    // (managed via the Admin SDK / a seeding script, never the client).
    match /products/{productId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /ingredients/{ingredientId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
