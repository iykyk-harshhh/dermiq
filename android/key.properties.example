# Copy to android/key.properties (git-ignored) and fill in to sign release builds.
# Generate a keystore once:
#   keytool -genkey -v -keystore ~/dermiq-upload.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias upload
storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=/absolute/path/to/dermiq-upload.jks
